# Copy this file to `.env`, add your live n8n webhook URLs, then run:
# ./scripts/generate-site-config.sh

# Shared webhook for every newsletter / interest signup form on the site.
DROP01_N8N_NEWSLETTER_SUBSCRIBE_WEBHOOK_URL="https://your-n8n-domain/webhook/drop01-newsletter-subscribe"

# Webhook for the general contact form on contact.html.
DROP01_N8N_GENERAL_CONTACT_WEBHOOK_URL="https://your-n8n-domain/webhook/drop01-general-contact"

# Webhook for the multi-step designer application / intake form.
DROP01_N8N_DESIGNER_INTAKE_WEBHOOK_URL="https://your-n8n-domain/webhook/drop01-designer-intake"

# Optional request timeout for frontend submissions, in milliseconds.
DROP01_FORM_SUBMIT_TIMEOUT_MS="10000"

# Shopify Storefront API configuration for automatic shop card/image syncing.
# The storefront access token is the public token created in Shopify's Headless channel.
DROP01_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
DROP01_SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-public-storefront-access-token"
DROP01_SHOPIFY_API_VERSION="2026-01"

# Optional collection handles. Leave blank to pull from all storefront products.
DROP01_SHOPIFY_COLLECTION_HANDLE=""
DROP01_SHOPIFY_HOME_COLLECTION_HANDLE=""
DROP01_SHOPIFY_SHOP_COLLECTION_HANDLE=""

# Optional product handle for the featured banner on shop.html.
DROP01_SHOPIFY_FEATURED_PRODUCT_HANDLE=""

# Optional per-page card counts.
DROP01_SHOPIFY_HOME_PRODUCT_LIMIT="3"
DROP01_SHOPIFY_SHOP_PRODUCT_LIMIT="6"
