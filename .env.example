# Copy this file to `.env`, add your live n8n webhook URLs, then run:
# ./scripts/generate-site-config.sh

# Shared webhook for every newsletter / interest signup form on the site.
DROP01_N8N_NEWSLETTER_SUBSCRIBE_WEBHOOK_URL="https://your-n8n-domain/webhook/drop01-newsletter-subscribe"

# Webhook for the general contact form on contact.html.
DROP01_N8N_GENERAL_CONTACT_WEBHOOK_URL="https://your-n8n-domain/webhook/drop01-general-contact"

# Webhook for the multi-step designer application / intake form.
DROP01_N8N_DESIGNER_INTAKE_WEBHOOK_URL="https://your-n8n-domain/webhook/drop01-designer-intake"

# Optional request timeout for frontend submissions, in milliseconds.
DROP01_FORM_SUBMIT_TIMEOUT_MS="10000"
